{
  "dashboard": {
    "id": null,
    "uid": "codelens-main",
    "title": "CodeLens — AI Code Review Dashboard",
    "tags": ["codelens", "api", "monitoring"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Review Latency (P50 / P95 / P99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(codelens_review_latency_seconds_bucket[5m]))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(codelens_review_latency_seconds_bucket[5m]))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(codelens_review_latency_seconds_bucket[5m]))",
            "legendFormat": "P99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "color": { "mode": "palette-classic" }
          }
        }
      },
      {
        "id": 2,
        "title": "Reviews Per Minute",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(codelens_review_count_total[5m])) * 60",
            "legendFormat": "Reviews/min"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "rpm" }
        }
      },
      {
        "id": 3,
        "title": "Cache Hit Ratio",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(codelens_cache_hit_total[5m])) / (sum(rate(codelens_cache_hit_total[5m])) + sum(rate(codelens_cache_miss_total[5m])))",
            "legendFormat": "Hit Ratio"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 0.5, "color": "yellow" },
                { "value": 0.8, "color": "green" }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Reviews by Type & Status",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "sum by (type, status) (codelens_review_count_total)",
            "legendFormat": "{{type}} - {{status}}"
          }
        ]
      },
      {
        "id": 5,
        "title": "Error Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(codelens_review_count_total{status=\"error\"}[5m]))",
            "legendFormat": "Errors/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "fixedColor": "red", "mode": "fixed" }
          }
        }
      },
      {
        "id": 6,
        "title": "Total Reviews (All Time)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
        "targets": [
          {
            "expr": "sum(codelens_review_count_total)",
            "legendFormat": "Total"
          }
        ]
      }
    ]
  }
}
